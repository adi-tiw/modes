{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "modes",
  "version": "0.1.0",
  "identifier": "com.adityatiwari.modes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "modes",
        "label": "main",
        "width": 250,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "shadow": false,
        "resizable": false,
        "url": "index.html"
      },
      {
        "title": "Settings",
        "label": "settings",
        "width": 800,
        "height": 800,
        "decorations": true,
        "center": true,
        "resizable": true,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
